# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_token_here

# OpenRouter API Key
OPENROUTER_API_KEY=your_key_here

# LLM Model (any OpenRouter model)
LLM_MODEL=openai/gpt-4o-mini

# TTS Model (any OpenRouter TTS model)
TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15
TTS_VOICE=alloy

# Local Whisper Server
WHISPER_URL=http://127.0.0.1:12017

# System prompt for the AI
SYSTEM_PROMPT=You are a helpful AI assistant. Respond concisely in Traditional Chinese (zh-TW).
